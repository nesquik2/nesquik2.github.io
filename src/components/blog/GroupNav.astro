---
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="group-nav" aria-label="Blog browsing groups">
  <a href={`${basePath}/blog/categories/`}>
    <span>Categories</span>
    <small>Browse by topic</small>
  </a>
  <a href={`${basePath}/blog/series/`}>
    <span>Series</span>
    <small>Follow connected notes</small>
  </a>
</nav>

<style>
  .group-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: calc(var(--page-header-spacing) * -0.45) 0 34px;
  }

  a {
    display: grid;
    gap: 4px;
    min-height: 74px;
    padding: 14px 16px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  a:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    transform: translateY(-1px);
  }

  span {
    font-family: var(--font-heading);
    font-size: 1.12rem;
    line-height: 1.2;
  }

  small {
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.76rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .group-nav {
      grid-template-columns: 1fr;
      margin-top: -10px;
    }
  }
</style>
